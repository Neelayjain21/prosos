/* ═══════════════════════════════════════════════════════════════
   PLACEMENT READINESS OPTIMIZATION SYSTEM — DESIGN SYSTEM
   Aesthetic: Precision Instrument / Aerospace Telemetry
   Fonts: Bebas Neue (display) · IBM Plex Mono (data) · DM Sans (prose)
═══════════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@300;400;500;700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap');

/* ── TOKENS ── */
:root {
  /* Base */
  --bg:       #050709;
  --bg1:      #0a0d12;
  --bg2:      #0f1318;
  --bg3:      #171c24;
  --bg4:      #1e2530;

  /* Borders */
  --b0:       rgba(255,255,255,0.04);
  --b1:       rgba(255,255,255,0.08);
  --b2:       rgba(255,255,255,0.14);
  --b3:       rgba(255,255,255,0.22);

  /* Signal colors */
  --signal:   #00ff88;      /* primary green */
  --signal-d: #00c866;      /* darker green */
  --signal-g: rgba(0,255,136,0.08);
  --signal-g2:rgba(0,255,136,0.14);
  --amber:    #ffb020;
  --amber-g:  rgba(255,176,32,0.08);
  --cyan:     #38bdf8;
  --cyan-g:   rgba(56,189,248,0.08);
  --red:      #ff4444;
  --red-g:    rgba(255,68,68,0.08);
  --purple:   #a78bfa;
  --purple-g: rgba(167,139,250,0.08);

  /* Text */
  --t0:  #f0f4f8;
  --t1:  #94a3b8;
  --t2:  #4a5568;
  --t3:  #2d3748;

  /* Typography */
  --ff-display: 'Bebas Neue', sans-serif;
  --ff-mono:    'IBM Plex Mono', monospace;
  --ff-body:    'DM Sans', sans-serif;

  /* Geometry */
  --r:   8px;
  --r2:  14px;
  --sh:  0 4px 32px rgba(0,0,0,0.5);
  --sh2: 0 0 0 1px var(--b1), 0 4px 32px rgba(0,0,0,0.5);
}

/* ── RESET ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; }
body {
  background: var(--bg);
  color: var(--t0);
  font-family: var(--ff-body);
  min-height: 100vh;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ── AMBIENT TEXTURE ── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 40% at 20% 10%, rgba(0,255,136,0.025) 0%, transparent 60%),
    radial-gradient(ellipse 50% 30% at 80% 80%, rgba(56,189,248,0.02) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

/* Fine grid */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
  z-index: 0;
}

/* ═══════════════════════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════════════════════ */
#root { position: relative; z-index: 1; }

.app-layout {
  display: flex;
  min-height: 100vh;
}

/* ── SIDEBAR NAV ── */
.sidebar {
  width: 220px;
  min-height: 100vh;
  background: var(--bg1);
  border-right: 1px solid var(--b1);
  display: flex;
  flex-direction: column;
  padding: 24px 0;
  position: fixed;
  top: 0; left: 0; bottom: 0;
  z-index: 50;
}

.sidebar-logo {
  padding: 0 20px 24px;
  border-bottom: 1px solid var(--b1);
  margin-bottom: 16px;
}

.sidebar-logo-mark {
  font-family: var(--ff-mono);
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--signal);
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.sidebar-logo-mark::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--signal);
  box-shadow: 0 0 8px var(--signal);
  animation: pulse-dot 2s infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--signal); }
  50% { opacity: 0.5; box-shadow: 0 0 2px var(--signal); }
}

.sidebar-title {
  font-family: var(--ff-mono);
  font-size: 13px;
  font-weight: 700;
  color: var(--t0);
  letter-spacing: 0.02em;
  line-height: 1.3;
}

.sidebar-nav {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 0 12px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: var(--r);
  font-family: var(--ff-mono);
  font-size: 12px;
  letter-spacing: 0.04em;
  color: var(--t2);
  text-decoration: none;
  cursor: pointer;
  transition: all 0.15s;
  border: 1px solid transparent;
  background: none;
  width: 100%;
  text-align: left;
}

.nav-item:hover { color: var(--t1); background: var(--bg3); }
.nav-item.active {
  color: var(--signal);
  background: var(--signal-g);
  border-color: rgba(0,255,136,0.15);
}

.nav-item-icon { font-size: 14px; opacity: 0.8; }

.sidebar-bottom {
  padding: 16px 12px 0;
  border-top: 1px solid var(--b1);
  margin-top: 16px;
}

/* ── MAIN CONTENT ── */
.main-content {
  margin-left: 220px;
  flex: 1;
  min-height: 100vh;
}

.page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 36px 32px 80px;
}

/* ── PAGE HEADER ── */
.page-header {
  margin-bottom: 32px;
}

.page-eyebrow {
  font-family: var(--ff-mono);
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--signal);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.page-eyebrow::before {
  content: '';
  width: 20px; height: 1px;
  background: var(--signal);
}

.page-title {
  font-family: var(--ff-display);
  font-size: 42px;
  letter-spacing: 0.04em;
  color: var(--t0);
  line-height: 1;
  margin-bottom: 6px;
}

.page-sub {
  font-size: 14px;
  color: var(--t1);
}

/* ═══════════════════════════════════════════════════════════════
   CARDS
═══════════════════════════════════════════════════════════════ */
.card {
  background: var(--bg1);
  border: 1px solid var(--b1);
  border-radius: var(--r2);
  padding: 24px;
  position: relative;
  overflow: hidden;
}

.card:hover { border-color: var(--b2); }

.card-signal  { border-top: 2px solid var(--signal); }
.card-amber   { border-top: 2px solid var(--amber); }
.card-cyan    { border-top: 2px solid var(--cyan); }
.card-red     { border-top: 2px solid var(--red); }
.card-purple  { border-top: 2px solid var(--purple); }

.card-glow-signal::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 60px;
  background: linear-gradient(180deg, var(--signal-g) 0%, transparent 100%);
  pointer-events: none;
}

.card-sm { padding: 16px 20px; }
.card-xs { padding: 12px 16px; }

.card-title {
  font-family: var(--ff-mono);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--t2);
  margin-bottom: 14px;
}

/* ═══════════════════════════════════════════════════════════════
   GRIDS
═══════════════════════════════════════════════════════════════ */
.grid-2  { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.grid-3  { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.grid-4  { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
.grid-5  { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
.stack   { display: flex; flex-direction: column; gap: 14px; }
.stack-sm{ display: flex; flex-direction: column; gap: 8px; }
.row     { display: flex; align-items: center; gap: 10px; }
.row-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1  { flex: 1; }
.span-2  { grid-column: span 2; }
.span-3  { grid-column: span 3; }

/* ═══════════════════════════════════════════════════════════════
   TYPOGRAPHY UTILITIES
═══════════════════════════════════════════════════════════════ */
.display-num {
  font-family: var(--ff-display);
  font-size: 64px;
  letter-spacing: 0.03em;
  line-height: 1;
}

.big-num {
  font-family: var(--ff-display);
  font-size: 42px;
  line-height: 1;
}

.med-num {
  font-family: var(--ff-display);
  font-size: 28px;
  line-height: 1;
}

.mono-sm {
  font-family: var(--ff-mono);
  font-size: 11px;
  letter-spacing: 0.06em;
}

.mono-xs {
  font-family: var(--ff-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
}

.label {
  font-family: var(--ff-mono);
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--t2);
}

.c-signal  { color: var(--signal); }
.c-amber   { color: var(--amber); }
.c-cyan    { color: var(--cyan); }
.c-red     { color: var(--red); }
.c-purple  { color: var(--purple); }
.c-muted   { color: var(--t1); }
.c-dim     { color: var(--t2); }

/* ═══════════════════════════════════════════════════════════════
   PROGRESS BARS
═══════════════════════════════════════════════════════════════ */
.prog-track {
  background: var(--bg3);
  border-radius: 3px;
  height: 5px;
  overflow: hidden;
  position: relative;
}

.prog-track-thick {
  background: var(--bg3);
  border-radius: 4px;
  height: 8px;
  overflow: hidden;
}

.prog-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
}

.prog-fill::after {
  content: '';
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 24px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4));
  animation: prog-shimmer 2s infinite;
}

@keyframes prog-shimmer {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

.prog-signal  { background: linear-gradient(90deg, #00aa55, var(--signal)); }
.prog-amber   { background: linear-gradient(90deg, #cc8800, var(--amber)); }
.prog-cyan    { background: linear-gradient(90deg, #1a7aaa, var(--cyan)); }
.prog-red     { background: var(--red); }
.prog-purple  { background: linear-gradient(90deg, #6d4fc9, var(--purple)); }

/* ═══════════════════════════════════════════════════════════════
   FORMS
═══════════════════════════════════════════════════════════════ */
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.form-group.full { grid-column: span 2; }

.form-label {
  font-family: var(--ff-mono);
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--t2);
}

.form-input {
  background: var(--bg2);
  border: 1px solid var(--b1);
  border-radius: var(--r);
  color: var(--t0);
  font-family: var(--ff-body);
  font-size: 14px;
  padding: 11px 14px;
  outline: none;
  transition: border-color 0.15s, box-shadow 0.15s;
  width: 100%;
}

.form-input:focus {
  border-color: rgba(0,255,136,0.35);
  box-shadow: 0 0 0 3px rgba(0,255,136,0.05);
}

.form-input::placeholder { color: var(--t3); }
select.form-input option { background: var(--bg2); }
textarea.form-input { resize: vertical; min-height: 80px; line-height: 1.6; }

/* ═══════════════════════════════════════════════════════════════
   BUTTONS
═══════════════════════════════════════════════════════════════ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-family: var(--ff-mono);
  font-size: 12px;
  letter-spacing: 0.06em;
  font-weight: 500;
  padding: 11px 22px;
  border-radius: var(--r);
  border: none;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  text-transform: uppercase;
}

.btn-primary {
  background: var(--signal);
  color: var(--bg);
  font-weight: 700;
}
.btn-primary:hover {
  background: #1aff99;
  box-shadow: 0 0 20px rgba(0,255,136,0.3);
  transform: translateY(-1px);
}
.btn-primary:active { transform: none; }

.btn-ghost {
  background: transparent;
  color: var(--t1);
  border: 1px solid var(--b2);
}
.btn-ghost:hover { color: var(--t0); border-color: var(--b3); background: var(--bg3); }

.btn-danger {
  background: var(--red-g);
  color: var(--red);
  border: 1px solid rgba(255,68,68,0.2);
}
.btn-danger:hover { background: rgba(255,68,68,0.2); }

.btn-sm { padding: 7px 14px; font-size: 11px; }
.btn-full { width: 100%; }

/* ═══════════════════════════════════════════════════════════════
   ALERTS
═══════════════════════════════════════════════════════════════ */
.alert {
  border-radius: var(--r);
  padding: 12px 16px;
  font-family: var(--ff-mono);
  font-size: 12px;
  line-height: 1.5;
  letter-spacing: 0.02em;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.alert-signal  { background: var(--signal-g);  border: 1px solid rgba(0,255,136,0.2);  color: var(--signal); }
.alert-warn    { background: var(--amber-g);   border: 1px solid rgba(255,176,32,0.2); color: var(--amber); }
.alert-danger  { background: var(--red-g);     border: 1px solid rgba(255,68,68,0.2);  color: var(--red); }
.alert-info    { background: var(--cyan-g);    border: 1px solid rgba(56,189,248,0.2); color: var(--cyan); }

/* ═══════════════════════════════════════════════════════════════
   MOOD PICKER
═══════════════════════════════════════════════════════════════ */
.mood-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
}

.mood-btn {
  padding: 12px 6px 10px;
  background: var(--bg2);
  border: 1px solid var(--b1);
  border-radius: var(--r);
  cursor: pointer;
  text-align: center;
  transition: all 0.15s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.mood-btn:hover { border-color: var(--b2); background: var(--bg3); }
.mood-btn.selected {
  border-color: var(--signal);
  background: var(--signal-g);
}

.mood-emoji { font-size: 22px; }
.mood-label {
  font-family: var(--ff-mono);
  font-size: 9px;
  letter-spacing: 0.08em;
  color: var(--t2);
  text-transform: uppercase;
}
.mood-btn.selected .mood-label { color: var(--signal); }

/* ═══════════════════════════════════════════════════════════════
   HEATMAP
═══════════════════════════════════════════════════════════════ */
.heatmap-wrap { overflow-x: auto; }

/* Override react-calendar-heatmap */
.react-calendar-heatmap text {
  font-family: var(--ff-mono) !important;
  font-size: 8px !important;
  fill: var(--t3) !important;
}

.react-calendar-heatmap .color-empty      { fill: var(--bg3); }
.react-calendar-heatmap .color-scale-1   { fill: rgba(0,255,136,0.2); }
.react-calendar-heatmap .color-scale-2   { fill: rgba(0,255,136,0.45); }
.react-calendar-heatmap .color-scale-3   { fill: rgba(0,255,136,0.7); }
.react-calendar-heatmap .color-scale-4   { fill: var(--signal); }
.react-calendar-heatmap rect { rx: 2; ry: 2; }

/* ═══════════════════════════════════════════════════════════════
   RECHARTS OVERRIDES
═══════════════════════════════════════════════════════════════ */
.recharts-cartesian-axis-tick-value {
  fill: var(--t2) !important;
  font-size: 10px !important;
  font-family: var(--ff-mono) !important;
}

.recharts-cartesian-grid-horizontal line,
.recharts-cartesian-grid-vertical line { stroke: var(--b1) !important; }

.recharts-tooltip-wrapper { outline: none !important; }

.recharts-default-tooltip {
  background: var(--bg2) !important;
  border: 1px solid var(--b2) !important;
  border-radius: var(--r) !important;
  box-shadow: var(--sh) !important;
}

.recharts-tooltip-label {
  color: var(--t1) !important;
  font-family: var(--ff-mono) !important;
  font-size: 11px !important;
  margin-bottom: 4px !important;
}

.recharts-tooltip-item {
  color: var(--t0) !important;
  font-family: var(--ff-mono) !important;
  font-size: 11px !important;
}

.recharts-legend-item-text {
  color: var(--t1) !important;
  font-size: 11px !important;
  font-family: var(--ff-mono) !important;
}

/* ═══════════════════════════════════════════════════════════════
   READINESS SCORE GAUGE
═══════════════════════════════════════════════════════════════ */
.score-ring {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-ring svg { transform: rotate(-90deg); }

.score-center {
  position: absolute;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* ═══════════════════════════════════════════════════════════════
   SUBJECT CARDS
═══════════════════════════════════════════════════════════════ */
.subject-card {
  background: var(--bg1);
  border: 1px solid var(--b1);
  border-radius: var(--r);
  padding: 14px 16px;
  transition: border-color 0.15s;
}

.subject-card:hover { border-color: var(--b2); }
.subject-card.neglected { border-color: rgba(255,68,68,0.3); background: rgba(255,68,68,0.03); }

/* ═══════════════════════════════════════════════════════════════
   LOG ENTRIES
═══════════════════════════════════════════════════════════════ */
.log-row {
  background: var(--bg1);
  border: 1px solid var(--b1);
  border-radius: var(--r);
  padding: 14px 16px;
  display: grid;
  grid-template-columns: 80px 1fr auto;
  gap: 14px;
  align-items: center;
  transition: border-color 0.15s, background 0.15s;
}

.log-row:hover { border-color: var(--b2); background: var(--bg2); }

.log-date-badge {
  background: var(--bg3);
  border-radius: 6px;
  padding: 8px;
  text-align: center;
}

.log-day-num {
  font-family: var(--ff-display);
  font-size: 28px;
  line-height: 1;
  color: var(--signal);
}

.log-month {
  font-family: var(--ff-mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--t2);
  margin-top: 2px;
}

/* ═══════════════════════════════════════════════════════════════
   LOGIN
═══════════════════════════════════════════════════════════════ */
.login-shell {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.login-panel {
  width: 100%;
  max-width: 420px;
}

.login-brand {
  text-align: center;
  margin-bottom: 40px;
}

.login-brand-mark {
  font-family: var(--ff-mono);
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--signal);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
}

.login-brand-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--signal);
  box-shadow: 0 0 10px var(--signal);
  animation: pulse-dot 2s infinite;
}

.login-brand-title {
  font-family: var(--ff-display);
  font-size: 36px;
  letter-spacing: 0.06em;
  color: var(--t0);
  line-height: 1.1;
  margin-bottom: 6px;
}

.login-brand-sub {
  font-size: 13px;
  color: var(--t1);
}

/* ═══════════════════════════════════════════════════════════════
   MODAL
═══════════════════════════════════════════════════════════════ */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.75);
  backdrop-filter: blur(4px);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.modal {
  background: var(--bg1);
  border: 1px solid var(--b2);
  border-radius: var(--r2);
  padding: 28px;
  width: 100%;
  max-width: 560px;
  animation: modal-in 0.2s cubic-bezier(0.22,1,0.36,1);
  position: relative;
}

@keyframes modal-in {
  from { opacity: 0; transform: translateY(16px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* ═══════════════════════════════════════════════════════════════
   TOAST
═══════════════════════════════════════════════════════════════ */
.toast-container {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 999;
  display: flex;
  flex-direction: column;
  gap: 8px;
  pointer-events: none;
}

.toast {
  background: var(--bg2);
  border: 1px solid var(--b2);
  border-radius: var(--r);
  padding: 12px 18px;
  font-family: var(--ff-mono);
  font-size: 12px;
  letter-spacing: 0.03em;
  color: var(--t0);
  box-shadow: var(--sh);
  animation: toast-in 0.25s cubic-bezier(0.22,1,0.36,1);
  pointer-events: auto;
  display: flex;
  align-items: center;
  gap: 10px;
}

.toast::before {
  content: '';
  width: 4px; height: 4px;
  border-radius: 50%;
  background: var(--signal);
  flex-shrink: 0;
}

.toast.error::before { background: var(--red); }
.toast.warn::before  { background: var(--amber); }

@keyframes toast-in {
  from { opacity: 0; transform: translateX(20px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ═══════════════════════════════════════════════════════════════
   LOADING
═══════════════════════════════════════════════════════════════ */
.loading-screen {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
}

.loading-spinner {
  width: 32px; height: 32px;
  border: 2px solid var(--b2);
  border-top-color: var(--signal);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  font-family: var(--ff-mono);
  font-size: 11px;
  letter-spacing: 0.15em;
  color: var(--t2);
  text-transform: uppercase;
}

/* ═══════════════════════════════════════════════════════════════
   DIVIDER
═══════════════════════════════════════════════════════════════ */
.divider {
  height: 1px;
  background: var(--b1);
  margin: 20px 0;
}

/* ═══════════════════════════════════════════════════════════════
   SCROLLBAR
═══════════════════════════════════════════════════════════════ */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--b2); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--b3); }

/* ═══════════════════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════════════════ */
@media (max-width: 768px) {
  .sidebar { width: 64px; }
  .sidebar-logo, .sidebar-title, .nav-item span { display: none; }
  .main-content { margin-left: 64px; }
  .grid-4, .grid-3 { grid-template-columns: repeat(2, 1fr); }
  .grid-2 { grid-template-columns: 1fr; }
  .page { padding: 24px 16px 60px; }
  .form-grid { grid-template-columns: 1fr; }
  .form-group.full { grid-column: span 1; }
  .display-num { font-size: 48px; }
  .span-2, .span-3 { grid-column: span 1; }
}
